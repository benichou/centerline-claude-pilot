# Copy to `.env` (gitignored) for the doc-intelligence tools (classify_document / extract_document_fields).
# The MCP server loads `.env` from the repo root at startup if present — present means live doc-intel works
# in BOTH Claude Code and Cowork (the server is host-spawned on both); absent is a no-op (the deterministic
# tools still run). The key lives here, NEVER in .mcp.json or claude_desktop_config.json.
#
#   cp .env.example .env   &&   edit .env

# Your personal Anthropic API key (pay-per-token). Required only for the live classify/extract calls.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the doc-intel model (default: claude-sonnet-4-6, the cost lever).
# CENTERLINE_DOCINTEL_MODEL=claude-sonnet-4-6
